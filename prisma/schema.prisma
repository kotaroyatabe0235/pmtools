// Environment
generator client {
  provider = "prisma-client-js"
}

// Database
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  avatar        String?
  role          String    @default("user") // "admin", "user"
  projects      Project[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Token Model
model Token {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  token       String   @unique
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  
  user        User     @relation("UserTokens", fields: [userId], references: [id])
}

// Project Model
model Project {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  ownerId        String   @map("owner_id")
  tags           Tag[]
  tasks          Task[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  owner          User     @relation("ProjectOwner", fields: [ownerId], references: [id])
}

// Tag Model
model Tag {
  id      Int         @id @default(autoincrement())
  name    String      @unique
  tasks   Task[]
}

// Task Model
model Task {
  id              String    @id @default(uuid())
  projectId       String    @map(project_id)
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  parentId        String?   @map(parent_id)
  startDate       DateTime  @map(start_date)
  endDate         DateTime? @map(end_date)
  duration        Int       @map(duration)
  progressRate    Decimal   @map(progress_rate) @default(0) @db.Decimal(5, 2)
  completionRate  Decimal   @map(completion_rate) @default(0) @db.Decimal(5, 2)
  actualStartDate DateTime? @map(actual_start_date)
  actualEndDate   DateTime? @map(actual_end_date)
  actualDuration  Int?      @map(actual_duration)
  startConstraint String    @map(start_constraint)
  priority        Int       @default(3)
  resourceId      String?   @map(resource_id)
  customFields    Json      @default("{}")
  position        Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  parent          Task?     @relation("TaskParent", fields: [parentId], references: [id], relatedId: "id")
  children        Task[]    @relation("TaskChildren")
  project         Project   @relation("ProjectTasks", fields: [projectId], references: [id])
  tags            Tag[]     @relation("TaskTags")
  resource        Resource? @relation("TaskResource", fields: [resourceId], references: [id])
  
  taskTags        TaskTag[]
}

// TaskTag Model (Many-to-Many)
model TaskTag {
  id        Int       @id @default(autoincrement())
  taskId    String    @map(task_id)
  tagId     Int       @map(tag_id)
  
  task      Task      @relation("TaskTaskTag", fields: [taskId], references: [id], onDelete: Cascade)
  tag       Tag       @relation("TagTaskTag", fields: [tagId], references: [id])
}

// Resource Model
model Resource {
  id          String    @id @default(uuid())
  projectId   String    @map(project_id)
  type        String    // "person", "team", "material"
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  userId      String?   @map(user_id)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  taskAssignments TaskAssignment[]
}

// TaskAssignment Model
model TaskAssignment {
  id          Int        @id @default(autoincrement())
  taskId      String     @map(task_id)
  resourceId  String     @map(resource_id)
  
  task        Task       @relation("TaskTaskAssignment", fields: [taskId], references: [id], onDelete: Cascade)
  resource    Resource   @relation("ResourceTaskAssignment", fields: [resourceId], references: [id], onDelete: Cascade)
}

// CustomField Model
model CustomField {
  id      Int       @id @default(autoincrement())
  name    String    @unique
  code    String    @unique
  type    String    // "text", "number", "select", "checkbox", "date"
  required Boolean @default(false)
  options  String[]
  
  taskFields CustomFieldValue[]
}

// CustomFieldValue Model
model CustomFieldValue {
  id       Int     @id @default(autoincrement())
  taskId   String   @map(task_id)
  fieldId   Int     @map(field_id)
  value    Json?   @default("{}")
  
  task     Task    @relation("TaskFields", fields: [taskId], references: [id], onDelete: Cascade)
  field    CustomField @relation("CustomFieldTask", fields: [fieldId], references: [id], onDelete: Cascade)
}
